# Copy to .env and fill in real values. Never commit the real .env.

# Neon Data API base URL, ends with /rest/v1
API_BASE_URL=https://YOUR-ENDPOINT.apirest.REGION.aws.neon.tech/neondb/rest/v1

# Bearer token for the Data API. Leave blank if using anonymous access
# (tables granted to the "anonymous" role, see sql/schema_additions.sql).
API_KEY=
